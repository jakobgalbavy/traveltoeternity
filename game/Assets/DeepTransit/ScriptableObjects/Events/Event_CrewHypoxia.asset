  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_CrewHypoxia
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_CrewHypoxia
  Title: Crew Hypoxia
  Description: "CO\u2082 saturation is dangerously high. Crew are incapacitated and
    unable to maintain ship systems."
  Severity: 2
  ChancePerHour: 0
  Precondition: 0
  Options:
  - Label: Emergency Scrubber Override
    RequiredRole: 1
    BaseSuccessChance: 0.55
    ContractorBonus: 0.35
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.1
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Scrubbers cleared. Crew recovering slowly.
    OnFailure:
      HullDamage: -0.05
      MoraleDelta: -0.3
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Override failed. Crew incapacitation deepens.
  - Label: Administer Stimulants
    RequiredRole: 3
    BaseSuccessChance: 0.7
    ContractorBonus: 0.25
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.05
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Stimulants buying time. Oxygen situation still critical.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.2
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Stimulants ineffective. Crew deteriorating.
  Escalation: {fileID: 11400000, guid: fad30720d193248c887e95a58453d8b3, type: 2}
  EscalationMinutes: 60
