  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_OxygenLoss
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_OxygenLoss
  Title: Oxygen Depletion
  Description: Cabin pressure is falling. The breach has compromised the oxygen recycler
    loop.
  Severity: 2
  ChancePerHour: 0
  Precondition: 0
  Options:
  - Label: Reroute Life Support
    RequiredRole: 1
    BaseSuccessChance: 0.6
    ContractorBonus: 0.3
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.1
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: "Life support rerouted. O\u2082 levels stabilising."
    OnFailure:
      HullDamage: -0.05
      MoraleDelta: -0.2
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Reroute failed. Pressure still dropping.
  - Label: "Emergency O\u2082 Canisters"
    RequiredRole: 0
    BaseSuccessChance: 0.85
    ContractorBonus: 0.1
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: 0
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Canisters deployed. Buys time but won't last.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.1
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: "Canister deployment too slow. CO\u2082 rising."
  Escalation: {fileID: 11400000, guid: b57e159427d7d479c90a9eb70151505d, type: 2}
  EscalationMinutes: 45
