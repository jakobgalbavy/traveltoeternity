  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_PassengerConflict
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_PassengerConflict
  Title: Passenger Conflict
  Description: A fight has broken out between colonist factions. Morale on deck is
    deteriorating.
  Severity: 1
  ChancePerHour: 0.07
  Precondition: 1
  Options:
  - Label: Mediate
    RequiredRole: 7
    BaseSuccessChance: 0.65
    ContractorBonus: 0.3
    OnSuccess:
      HullDamage: 0
      MoraleDelta: 0.1
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Conflict de-escalated. Tensions remain but manageable.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.2
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Mediation failed. Situation escalated.
  - Label: Security Intervention
    RequiredRole: 5
    BaseSuccessChance: 0.7
    ContractorBonus: 0.25
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.05
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Parties separated. Uneasy calm restored.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.15
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Security overwhelmed. Brawl spread.
  Escalation: {fileID: 0}
  EscalationMinutes: 120
