%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_CryoFault
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_CryoFault
  Title: Cryo Bay Fault
  Description: Temperature variance detected in Cryo Bay 2. Occupants are at risk
    of premature thaw if the fault is not isolated immediately.
  Severity: 2
  ChancePerHour: 0.05
  Precondition: 1
  Options:
  - Label: Cryo Tech Intervention
    RequiredRole: 9
    BaseSuccessChance: 0.72
    ContractorBonus: 0.28
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: 0.05
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Cryo systems stabilised. All occupants safe.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.2
      CargoDamage: -0.05
      FoodDelta: 0
      LogMessage: Fault cascaded. Multiple premature thaws.
  - Label: Emergency Isolation
    RequiredRole: 1
    BaseSuccessChance: 0.55
    ContractorBonus: 0.25
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.05
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Bay isolated. Occupants transferred to contingency berths.
    OnFailure:
      HullDamage: -0.03
      MoraleDelta: -0.15
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Isolation failed. Thermal runaway in bay systems.
  Escalation: {fileID: 0}
  EscalationMinutes: 60
