%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_EngineMalfunction
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_EngineMalfunction
  Title: Engine Malfunction
  Description: Irregular drive output detected. Thrust is degrading and structural
    stress is mounting. Uncorrected, the vibrations will crack the hull.
  Severity: 1
  ChancePerHour: 0.1
  Precondition: 0
  Options:
  - Label: Diagnostic Repair
    RequiredRole: 1
    BaseSuccessChance: 0.6
    ContractorBonus: 0.3
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: 0.03
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Drive repaired. Output nominal.
    OnFailure:
      HullDamage: -0.1
      MoraleDelta: -0.05
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Repair failed. Vibrations worsening.
  - Label: Emergency Shutdown
    RequiredRole: 0
    BaseSuccessChance: 0.78
    ContractorBonus: 0.1
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.05
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Drive shut down safely. Speed reduced but ship is stable.
    OnFailure:
      HullDamage: -0.08
      MoraleDelta: -0.1
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Shutdown botched. Surge before cutoff.
  Escalation: {fileID: 11400000, guid: e58165dc2329942938065f8381ce19ca, type: 2}
  EscalationMinutes: 90
