MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_HullBreach
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_HullBreach
  Title: Hull Breach
  Description: "A section of hull has failed. Decompression in progress \u2014 oxygen
    is venting."
  Severity: 2
  ChancePerHour: 0.02
  Precondition: 3
  Options:
  - Label: Emergency Seal
    RequiredRole: 1
    BaseSuccessChance: 0.5
    ContractorBonus: 0.35
    IsPartialFix: 0
    OnSuccess:
      HullDamage: -0.15
      MoraleDelta: -0.1
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Breach sealed. Structural integrity reduced.
    OnFailure:
      HullDamage: -0.35
      MoraleDelta: -0.25
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Seal failed. Major decompression event.
  Escalation: {fileID: 11400000, guid: 7c721d1987c99474ab78695c1df35ab6, type: 2}
  EscalationMinutes: 60
