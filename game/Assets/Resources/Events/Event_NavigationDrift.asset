%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_NavigationDrift
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_NavigationDrift
  Title: Navigation Drift
  Description: Calibration error in the nav array has allowed course drift to accumulate.
    A correction burn is needed or we'll miss the arrival window.
  Severity: 0
  ChancePerHour: 0.09
  Precondition: 0
  Options:
  - Label: Recalibrate Array
    RequiredRole: 4
    BaseSuccessChance: 0.7
    ContractorBonus: 0.25
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: 0.02
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Array recalibrated. Back on course.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.05
      CargoDamage: -0.08
      FoodDelta: 0
      LogMessage: Calibration failed. Rough correction burn required.
  - Label: Manual Override
    RequiredRole: 0
    BaseSuccessChance: 0.48
    ContractorBonus: 0.05
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.03
      CargoDamage: 0
      FoodDelta: 0
      LogMessage: Manual correction complete. Slightly behind schedule.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.1
      CargoDamage: -0.12
      FoodDelta: 0
      LogMessage: Manual correction overshoot. Cargo rattled.
  Escalation: {fileID: 0}
  EscalationMinutes: 90
