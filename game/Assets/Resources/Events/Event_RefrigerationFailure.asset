  m_Script: {fileID: 11500000, guid: 6095d0d909ea04dbda0d82d6d58fe81a, type: 3}
  m_Name: Event_RefrigerationFailure
  m_EditorClassIdentifier: DeepTransit.Runtime::DeepTransit.Events.GameEventSO
  Id: Event_RefrigerationFailure
  Title: Refrigeration Failure
  Description: Cold storage units have malfunctioned. Provisions are warming rapidly.
    If not addressed, spoilage will cascade to the grow bay.
  Severity: 1
  ChancePerHour: 0.08
  Precondition: 0
  Options:
  - Label: Repair Cold Storage
    RequiredRole: 10
    BaseSuccessChance: 0.65
    ContractorBonus: 0.3
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: 0
      CargoDamage: 0
      FoodDelta: 0.03
      LogMessage: Cold storage repaired. Provisions saved.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.08
      CargoDamage: 0
      FoodDelta: -0.15
      LogMessage: Repair failed. Significant spoilage.
  - Label: Emergency Rationing
    RequiredRole: 0
    BaseSuccessChance: 0.82
    ContractorBonus: 0.08
    IsPartialFix: 0
    OnSuccess:
      HullDamage: 0
      MoraleDelta: -0.05
      CargoDamage: 0
      FoodDelta: -0.07
      LogMessage: Rationing implemented. Most provisions preserved.
    OnFailure:
      HullDamage: 0
      MoraleDelta: -0.12
      CargoDamage: 0
      FoodDelta: -0.2
      LogMessage: Rationing too late. Heavy spoilage.
  Escalation: {fileID: 11400000, guid: 8969c189ea0c049318af3e094e06b6a9, type: 2}
  EscalationMinutes: 75
